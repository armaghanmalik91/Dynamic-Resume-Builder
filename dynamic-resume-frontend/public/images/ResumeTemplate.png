acing--xxl); --mat-button-outlined-outline-color: var(--gem-sys-color--outl=
ine); --mat-button-outlined-state-layer-color: var(--gem-sys-color--primary=
); --mat-button-outlined-label-text-color: var(--gem-sys-color--primary); }

